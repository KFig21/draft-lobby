# Server config
PORT=4100
# Comma-separated if you have more than one (e.g. your Vercel prod domain +
# a preview deployment URL) — no spaces needed, they're trimmed.
CLIENT_ORIGIN=http://localhost:5183

# Supabase — from your project's Settings > API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Postgres connection string for running migrations (npm run db:migrate).
# Supabase → Settings → Database → Connection string (URI, includes password).
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

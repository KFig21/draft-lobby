# Supabase — from your project's Settings > API (anon/public key only; never the service role key)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Leave unset for local dev (Vite proxies /api to the local server). In
# production (Vercel), set this to your deployed API's origin (e.g. your
# Railway URL) since the client and server are hosted separately there.
VITE_API_URL=
